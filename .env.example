# =========================================================================
# iFastX WhatsApp Gateway - Environment Configuration Template
# =========================================================================

# 1. Server Configuration
PORT=4000
NODE_ENV=production

# Your public URL (e.g., https://wa-api.ifastx.in)
APP_URL=https://your-domain.com

# 2. Database Configuration (PostgreSQL)
# Format: postgres://[user]:[password]@[host]:[port]/[database]
# For your setup, the database name is: ifastx_db
# Note: If your password contains special characters like @, they MUST be URL-encoded (e.g. @ becomes %40)
DATABASE_URL=postgres://postgres:iFastX%40Admin2024@localhost:5432/ifastx_db

# 3. Redis Configuration (Required for BullMQ Messaging Queue)
# Format: redis://[host]:[port]
REDIS_URL=redis://127.0.0.1:6379

# 4. Security & JWT Configuration
# Change these to long, random strings in production
JWT_SECRET=ifastx_internal_secure_2024_09_v2
REFRESH_SECRET=ifastx_refresh_rotation_secure_v2

# 5. External Integration Tokens (Optional)
# Used for the internal mail bridge for OTP/Password Resets
INTERNAL_BRIDGE_TOKEN=ifastx_internal_bridge_9922

# =========================================================================
# INSTRUCTIONS:
# 1. Copy this file to '.env'
# 2. Update DATABASE_URL with your actual PostgreSQL password.
# 3. Ensure Redis is running locally or update REDIS_URL.
# 4. Restart the backend service (pm2 restart wa-api).
# =========================================================================GEMINI_API_KEY=
