{
  "name": "whatsapp-api-backend",
  "version": "1.0.0",
  "description": "Backend for WhatsApp Instance Manager Pro",
  "main": "index.js",
  "scripts": {
    "start": "node server.cjs",
    "pm2:start": "pm2 start server.cjs --name \"wa-api\" --ignore-watch=\"sessions node_modules\"",
    "pm2:stop": "pm2 stop wa-api && pm2 delete wa-api",
    "dev": "node server.cjs",
    "build": "vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "@google/genai": "^2.11.0",
    "@whiskeysockets/baileys": "^6.7.7",
    "bullmq": "^5.12.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "emoji-picker-react": "^4.18.0",
    "express": "^4.19.2",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "link-preview-js": "^3.0.0",
    "lucide-react": "^0.575.0",
    "node-cache": "^5.1.2",
    "node-cron": "^4.6.0",
    "pg": "^8.12.0",
    "pino": "^9.4.0",
    "qrcode-terminal": "^0.12.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.7.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9.39.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
